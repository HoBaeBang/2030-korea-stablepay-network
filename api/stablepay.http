@baseUrl = http://localhost:8080

# StablePay API 실행 예시
#
# 사용 순서:
# 1. Health check로 서버가 켜져 있는지 확인한다.
# 2. Create merchant를 실행하고 응답의 id 값을 merchantId에 복사한다.
# 3. Create invoice를 실행하고 응답의 id 값을 invoiceId에 복사한다.
# 4. Create payment를 실행하고 응답의 id 값을 paymentId에 복사한다.
# 5. Detect on-chain payment, Finalize payment 순서로 상태를 변경한다.

@merchantId = mer_응답에서_복사
@invoiceId = inv_응답에서_복사
@paymentId = pay_응답에서_복사

### 1. Health check
GET {{baseUrl}}/health

### 2. Create merchant
POST {{baseUrl}}/merchants
Content-Type: application/json

{
  "name": "Cafe Korea",
  "email": "owner@cafe.example"
}

### 3. Create invoice
POST {{baseUrl}}/merchants/{{merchantId}}/invoices
Content-Type: application/json

{
  "amount": 10000,
  "currency": "USDC"
}

### 4. Create invoice with expiration
POST {{baseUrl}}/merchants/{{merchantId}}/invoices
Content-Type: application/json

{
  "amount": 25000,
  "currency": "USDC",
  "expires_at": "2026-06-30T15:00:00Z"
}

### 5. Create payment
POST {{baseUrl}}/invoices/{{invoiceId}}/payments
Content-Type: application/json

{
  "amount": 10000,
  "currency": "USDC"
}

### 6. Detect on-chain payment
PATCH {{baseUrl}}/payments/{{paymentId}}/status
Content-Type: application/json

{
  "status": "ONCHAIN_DETECTED",
  "transaction_hash": "0xabc123"
}

### 7. Finalize payment
PATCH {{baseUrl}}/payments/{{paymentId}}/status
Content-Type: application/json

{
  "status": "FINALIZED"
}

### 8. Invalid transition example
PATCH {{baseUrl}}/payments/{{paymentId}}/status
Content-Type: application/json

{
  "status": "PENDING"
}

### 9. Invalid merchant email example
POST {{baseUrl}}/merchants
Content-Type: application/json

{
  "name": "Invalid Merchant",
  "email": "invalid-email"
}

### 10. Unsupported currency example
POST {{baseUrl}}/invoices/{{invoiceId}}/payments
Content-Type: application/json

{
  "amount": 10000,
  "currency": "KRW"
}
